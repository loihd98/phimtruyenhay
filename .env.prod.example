# ============================================
# Production Environment Configuration
# Copy this file to .env.prod and fill in values
# ============================================

# Database
POSTGRES_DB=web_truyen
POSTGRES_USER=webtruyen_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}

# JWT Secrets (generate with: openssl rand -base64 48)
JWT_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_base64_48
JWT_REFRESH_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_base64_48

# OAuth (optional — leave empty to disable)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# Base URLs
BASE_URL=https://phimtruyenhay.com
CORS_ORIGIN=https://phimtruyenhay.com
FRONTEND_URL=https://phimtruyenhay.com
BACKEND_URL=https://phimtruyenhay.com
DOMAIN=phimtruyenhay.com

# Frontend (Next.js public env vars — baked into build)
NEXT_PUBLIC_API_URL=https://phimtruyenhay.com/api
NEXT_PUBLIC_BASE_URL=https://phimtruyenhay.com
NEXT_PUBLIC_MEDIA_URL=https://phimtruyenhay.com
NEXT_PUBLIC_SITE_URL=https://phimtruyenhay.com

# Server-side API URL (internal Docker network — used for SSR)
API_URL=http://backend:5000/api

# File upload
MAX_FILE_SIZE=10485760
UPLOAD_PATH=/uploads

# Environment
NODE_ENV=production
PORT=5000
FRONTEND_PORT=3000

# Email / Contact Form (SMTP via Gmail)
# To get an App Password: Google Account > Security > 2-Step Verification > App passwords
SMTP_USER=hideonstorms@gmail.com
SMTP_PASS=your-gmail-app-password
ADMIN_EMAIL=hideonstorms@gmail.com
