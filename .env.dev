# ============================================
# Development Environment Configuration
# Copy this file to .env.dev and fill in values
# ============================================

# Database
DATABASE_URL="postgresql://postgres:postgres123@postgres:5432/webtruyen_dev"
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres123
POSTGRES_DB=webtruyen_dev

# Application
NODE_ENV=development
PORT=5000

# Domain and URLs
DOMAIN=localhost
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:5000

# Next.js Public Variables
NEXT_PUBLIC_API_URL=http://localhost/api
NEXT_PUBLIC_FRONTEND_URL=http://localhost
NEXT_PUBLIC_MEDIA_URL=http://localhost
NEXT_PUBLIC_SITE_URL=http://localhost

# Server-side API URL (internal Docker network)
API_URL=http://backend:5000/api

# JWT
JWT_SECRET=dev_jwt_secret_key_for_development_only
JWT_REFRESH_SECRET=dev_refresh_secret_key_for_development_only

# File Upload
UPLOAD_DIR=/uploads
MAX_FILE_SIZE=10485760

# OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# CORS
CORS_ORIGIN=http://localhost
